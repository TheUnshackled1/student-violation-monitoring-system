# =============================================================
#  CHMSU Student Violation Monitoring System — .gitignore
#  Stack: Python 3.11 · Django 5.2 · PostgreSQL / SQLite
#         OpenCV · gTTS · Pillow · WhiteNoise · Channels
# =============================================================

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST
.Python

# ──────────────────────────────────────────────
# Virtual Environments
# ──────────────────────────────────────────────
virtualenv/
venv/
env/
.env/
.venv/
ENV/
env.bak/
venv.bak/

# ──────────────────────────────────────────────
# Django
# ──────────────────────────────────────────────

# Local settings override (never commit secrets)
student_violation_system/local_settings.py

# SQLite development database
db.sqlite3
db.sqlite3-journal
*.sqlite3

# Collected static files (generated by collectstatic)
staticfiles/

# Uploaded user media (apology letters, profiles, evidence)
media/

# Django migrations — uncomment if you want to exclude them
# violations/migrations/

# ──────────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────────
.env
.env.*
!.env.example
*.env
secrets.json
local_config.py

# ──────────────────────────────────────────────
# Database dumps & backups
# ──────────────────────────────────────────────
*.sql
*.dump
*.bak
*.backup

# ──────────────────────────────────────────────
# OpenCV / NumPy / gTTS / Pillow artifacts
# ──────────────────────────────────────────────
# Temporary audio files generated by gTTS
*.mp3
# Temporary image/video artifacts from OpenCV
*.avi
*.mp4
# NumPy binary files
*.npy
*.npz

# ──────────────────────────────────────────────
# Logs & Runtime
# ──────────────────────────────────────────────
*.log
*.pid
celerybeat-schedule
celerybeat.pid
gunicorn.pid
gunicorn-error.log
django.log

# ──────────────────────────────────────────────
# Testing & Coverage
# ──────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
htmlcov/
.pytest_cache/
nosetests.xml
test-results/

# ──────────────────────────────────────────────
# Jupyter / IPython
# ──────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ──────────────────────────────────────────────
# IDEs & Editors
# ──────────────────────────────────────────────

# PyCharm / IntelliJ
.idea/

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*~
*.swp
*.swo
.#*
\#*\#

# ──────────────────────────────────────────────
# Windows OS
# ──────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# ──────────────────────────────────────────────
# macOS (if collaborating cross-platform)
# ──────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ──────────────────────────────────────────────
# Node / Frontend (if added later)
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────
# Miscellaneous
# ──────────────────────────────────────────────
*.tmp
*.temp
*.orig
*.rej
*.patch
